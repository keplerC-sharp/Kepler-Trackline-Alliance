@model Kepler_Trackline_Alliance.ViewModels.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KEPLER CONTROL — Access Gateway</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow:wght@400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/styles.css">
</head>
<body>

<!-- GLOBAL NOTIFICATION LAYER -->
<div class="toast-container" id="toastContainer"></div>

<!-- SYSTEM LOADING INTERSTITIAL -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-spinner"></div>
  <div class="loading-text">Synchronizing credentials with master server...</div>
</div>

<div class="screen active" id="screen-login">
  <div class="login-bg"></div>
  <div class="track-lines"></div>

  <div class="login-wrap">
    <!-- LOGO & BRANDING BLOCK -->
    <div class="login-logo">
      <div class="icon-shield"><i class="bi bi-shield-fill-check"></i></div>
      <div class="brand-name">KEPLER <span>CONTROL</span></div>
      <div class="brand-sub">Secure Entry Gateway</div>
    </div>

    <!-- FEEDBACK: Administrative Success Alerts -->
    @if (TempData["Success"] != null)
    {
      <div class="alert alert-success" style="font-family:var(--font-mono); font-size:0.75rem; border-radius:3px;">
        @TempData["Success"]
      </div>
    }

    <!-- COMPONENT: Authentication Interface -->
    <form asp-action="Login" asp-controller="Auth" method="post" id="loginForm">
      <div class="login-card">
        <div class="z-field">
          <label class="field-label">Marshal Identification (ID)</label>
          <div class="input-wrap">
            <i class="bi bi-person-badge"></i>
            <input class="z-input" asp-for="Identifier" type="text" placeholder="ID_ALPHA_00" autocomplete="off">
          </div>
          <span asp-validation-for="Identifier" class="text-danger" style="font-size:0.7rem;"></span>
        </div>

        <div class="z-field">
          <label class="field-label">Secure Access Key</label>
          <div class="input-wrap">
            <i class="bi bi-key"></i>
            <input class="z-input" asp-for="Password" type="password" placeholder="••••••••">
          </div>
          <span asp-validation-for="Password" class="text-danger" style="font-size:0.7rem;"></span>
        </div>

        <!-- VALIDATION: Global Authentication Faults -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
        {
          <div style="color:var(--red); font-family:var(--font-mono); font-size:0.7rem; margin-bottom:8px;">
            @Html.ValidationMessage("")
          </div>
        }

        <div class="d-flex align-items-center justify-content-between" style="margin-top:4px;">
          <label class="z-check">
            <input type="checkbox" asp-for="Remember">
            <span>Remember Station</span>
          </label>
          <a href="/Auth/Register" class="z-link">New Operator?</a>
        </div>

        <button type="submit" class="btn-access" id="loginBtn">
          <i class="bi bi-lightning-fill"></i>
          Initialize Access
        </button>
      </div>
    </form>

    <!-- STATUS HUD: Operational Integrity indicators -->
    <div class="status-bar">
      <div class="status-badge">
        <div class="status-dot"></div><span>Telemetry Uplink</span>
      </div>
      <div class="status-badge">
        <div class="status-dot red"></div><span>AES-256 Encryption</span>
      </div>
    </div>

    <div style="text-align:center; margin-top:20px;">
      <small style="font-family:var(--font-mono); font-size:0.52rem; letter-spacing:0.12em; color:var(--text-muted);">
        © 2025 KEPLER PERFORMANCE TECHNOLOGIES — AUTHORIZED PERSONNEL ONLY
      </small>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/shared.js"></script>
<script>
/**
 * Triggers the loading overlay to provide visual feedback during the 
 * asynchronous authentication handshake.
 */
document.getElementById('loginForm').addEventListener('submit', function() {
  document.getElementById('loadingOverlay').classList.add('active');
});
</script>
</body>
</html>

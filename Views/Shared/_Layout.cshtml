<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kepler Trackline Alliance</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,900&family=Barlow:wght@400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    
    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Custom Cyber Styles -->
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
</head>
<body class="screen active" id="screen-dashboard">
    <header class="topbar">
        <!-- Header vaciado por solicitud del usuario -->
    </header>

    <div class="dashboard-body">
        <aside class="sidebar" id="sidebar">
            <!-- Rendered by shared.js/initLayout -->
        </aside>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <div class="overlay" id="mobileOverlay" onclick="closeSidebar()"></div>
    <div class="toast-container" id="toastContainer"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/shared.js" asp-append-version="true"></script>
    
    <script>
        // Inicializar el layout global con el ID de la página activa
        document.addEventListener('DOMContentLoaded', () => {
            const controller = '@ViewContext.RouteData.Values["controller"]?.ToString()';
            let activeId = 'registry';
            if (controller === 'Queue') activeId = 'cola';
            initLayout(activeId);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model Kepler_Trackline_Alliance.Models.ErrorViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX CONTROL — Error</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/styles.css">
<style>
  body { display:flex; align-items:center; justify-content:center; min-height:100vh; }
  .err-box { text-align:center; max-width:500px; padding:40px; }
  .err-code { font-family:var(--font-display); font-size:5rem; font-weight:900; color:var(--red); line-height:1; }
  .err-msg  { font-family:var(--font-mono); font-size:0.75rem; letter-spacing:0.2em; color:var(--text-muted); text-transform:uppercase; margin:16px 0 32px; }
</style>
</head>
<body>
<div class="err-box">
  <div class="err-code"><i class="bi bi-exclamation-octagon-fill"></i></div>
  <div class="err-msg">Error interno del servidor</div>
  @if (Model?.ShowRequestId == true)
  {
    <div style="font-family:var(--font-mono); font-size:0.6rem; color:var(--text-muted); margin-bottom:24px;">
      Request ID: @Model.RequestId
    </div>
  }
  <a href="/Queue/Index" class="btn-primary" style="text-decoration:none; display:inline-flex;">
    <i class="bi bi-house-fill"></i> Volver al inicio
  </a>
</div>
</body>
</html>

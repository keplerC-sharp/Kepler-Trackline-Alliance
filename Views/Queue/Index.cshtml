@model Kepler_Trackline_Alliance.ViewModels.QueueViewModel
@{
  ViewData["Title"] = "Track Control";
}

<!-- Hidden metadata for JavaScript session synchronization -->
<input type="hidden" id="activeSessionId" value="@Model.SessionId" />

<div class="row g-4">
  @if (Model.SessionId == 0)
  {
    <div class="col-12">
      <div class="z-panel" style="border-color:var(--cyan); background:rgba(0,183,255,0.01); padding:60px 20px; display:flex; align-items:center; justify-content:center;">
        <div class="panel-body text-center" style="max-width:540px; width:100%;">
          <div class="mb-4" style="position:relative; display:inline-block;">
             <i class="bi bi-broadcast" style="font-size:clamp(3rem, 10vw, 5rem); color:var(--cyan); opacity:0.15;"></i>
             <i class="bi bi-play-circle" style="font-size:clamp(1.5rem, 5vw, 2.5rem); color:var(--cyan); position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-shadow: 0 0 15px rgba(0,229,255,0.5);"></i>
          </div>
          <h2 class="mt-2" style="font-family:var(--font-display); font-weight:900; letter-spacing:0.12em; font-size:clamp(1.8rem, 6vw, 2.8rem);">NO LIVE SESSION</h2>
          <div style="height:2px; width:60px; background:var(--cyan); margin:20px auto; opacity:0.4;"></div>
          <p class="text-dim" style="font-family:var(--font-mono); letter-spacing:0.12em; text-transform:uppercase; font-size:clamp(0.6rem, 2vw, 0.75rem); line-height:1.8; color:var(--text-dim);">
            System Standby · Telemetry Link Inactive<br>
            Initiate a new track session to authorize pilot onboarding and stint management.
          </p>
          <form asp-controller="Session" asp-action="Start" method="post">
            <button type="submit" class="btn-primary mt-4" style="padding:15px 40px; font-size:clamp(0.9rem, 3vw, 1.1rem); box-shadow:0 0 30px rgba(0,229,255,0.2);">
              <i class="bi bi-lightning-fill"></i> START TRACK SESSION
            </button>
          </form>
        </div>
      </div>
    </div>
  }
  else
  {
    <!-- PRIMARY STACK: Track Queue Display -->
    <div class="col-lg-8">
      <div class="z-panel">
        <div class="panel-title">
          <i class="bi bi-list-ol"></i> Track Queue
        </div>
        <div class="panel-body">
          <!-- Real-time Performance Metrics -->
          <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
              <div class="stat-mini">
                <div class="stat-mini-val" id="statDone" style="color:var(--green);">0</div>
                <div class="stat-mini-label">Completed</div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="stat-mini">
                <div class="stat-mini-val" id="statQueued" style="color:var(--yellow);">0</div>
                <div class="stat-mini-label">Queued</div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="stat-mini">
                <div class="stat-mini-val" id="statAvgTime" style="color:var(--cyan);">0m</div>
                <div class="stat-mini-label">Avg. Duration</div>
              </div>
            </div>
            <div class="col-6 col-md-3">
              <div class="stat-mini">
                <div class="stat-mini-val" id="statTurnRate" style="color:var(--orange);">0/h</div>
                <div class="stat-mini-label">Turn Rate</div>
              </div>
            </div>
          </div>

          <!-- Dynamic Banner: Alerts operator of incoming pilot readiness -->
          <div id="nextPilotBanner" class="status-log mb-4" style="display:none; border-color:var(--yellow); background:rgba(255,214,0,0.02);">
            <div class="status-log-title" style="color:var(--yellow);">
              <i class="bi bi-person-up"></i> Upcoming Readiness
            </div>
            <div class="status-log-body" id="nextPilotName" style="font-weight:700; font-size:1rem; color:var(--text);">
              Loading pilot data...
            </div>
          </div>

          <div class="queue-list" id="queueList">
            <div class="text-center py-5 text-dim">
              <div class="spinner-border spinner-border-sm mb-2"></div>
              <p>Synchronizing with live track data...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CONTROL STACK: Session & Stint Management -->
    <div class="col-lg-4">
      <div class="z-panel red-accent">
        <div class="panel-title">
          <i class="bi bi-lightning-fill"></i> Stint Control
        </div>
        <div class="panel-body">
          <div id="currentTurnPanel">
            <div class="text-center py-4 text-muted">
              No Active Stint
            </div>
          </div>

          <!-- Chronometer and Progress Tracking -->
          <div class="mt-4">
            <div id="bigTimer" class="big-timer">--:--</div>
            <div class="progress-bar-wrap mt-2" style="height:6px;">
              <div id="mainProgressBar" class="progress-bar-fill" style="width:0%;"></div>
            </div>
          </div>

          <div style="display:flex;flex-direction:column;margin-top:16px;gap:10px;">
            <div style="display:flex;gap:8px;">
              <button id="btnFinish" class="btn-primary" style="flex:1;justify-content:center;background:var(--red);border-color:var(--red);color:var(--bg);" onclick="finishTurn()">
                <i class="bi bi-stop-circle-fill"></i> Finish Turn
              </button>
              <button id="btnStart" class="btn-primary" style="flex:1;justify-content:center;background:var(--green);border-color:var(--green);color:var(--bg);" onclick="startTurn()">
                <i class="bi bi-play-circle-fill"></i> Start Turn
              </button>
            </div>
            <div style="display:flex;gap:8px;">
              <button id="btnAdvance" class="btn-primary" style="flex:1;justify-content:center;background:var(--cyan);border-color:var(--cyan);color:var(--bg);" onclick="advanceQueue()">
                <i class="bi bi-skip-forward-circle-fill"></i> Finish & Next
              </button>
            </div>
            <div style="display:flex;gap:8px;">
              <button class="btn-outline" style="flex:1;justify-content:center;" onclick="reannounceCurrent()">
                <i class="bi bi-megaphone-fill"></i> Re-call Pilot
              </button>
              <a href="/Dashboard/Index" class="btn-outline"
                 style="flex:1;justify-content:center;text-decoration:none;">
                <i class="bi bi-person-plus"></i> New Entry
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- ADMINISTRATIVE: Session Finalization -->
      <div class="mt-4">
        <button type="button" class="btn-outline w-100" style="border-color:var(--red); color:var(--red); justify-content:center;" data-bs-toggle="modal" data-bs-target="#closeSessionModal">
          <i class="bi bi-stop-circle me-2"></i> CLOSE TRACK SESSION
        </button>
      </div>
    </div>
  }
</div>

<!-- Close Session Modal -->
<div class="modal fade" id="closeSessionModal" tabindex="-1" aria-labelledby="closeSessionModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content z-panel" style="background-color: var(--bg2); color: var(--text); border: 1px solid var(--border); border-top: 2px solid var(--red);">
      <form asp-controller="Session" asp-action="End" method="post">
        <div class="modal-header" style="border-bottom: 1px solid var(--border); background-color: var(--panel);">
          <h5 class="modal-title" id="closeSessionModalLabel" style="color: var(--red); font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700;">
            <i class="bi bi-exclamation-triangle-fill"></i> End Track Session
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="background-color: var(--bg2);">
          <p style="color: var(--text-dim); font-size: 0.95rem;">Are you sure you want to finalize the current track session? This action is irreversible.</p>
          <div class="mt-4 mb-3">
            <label for="reportEmail" class="field-label" style="color: var(--cyan); margin-bottom: 8px;">SEND SESSION REPORT TO (OPTIONAL)</label>
            <input type="email" class="z-field-input" id="reportEmail" name="email" placeholder="operator@example.com">
            <div class="form-text mt-2" style="color: var(--text-dim); font-size: 0.8rem; font-family: var(--font-mono);">Leave blank if you do not wish to receive a report.</div>
          </div>
          <input type="hidden" name="sessionId" value="@Model.SessionId" />
        </div>
        <div class="modal-footer" style="border-top: 1px solid var(--border); background-color: var(--panel);">
          <button type="button" class="btn-outline" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-primary" style="background:var(--red);border-color:var(--red);color:white;">
            <i class="bi bi-stop-circle me-2"></i> Finalize Session
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
@section Scripts {
  <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
  <script src="~/js/cola.js" asp-append-version="true"></script>
}

@{ Layout = null; }

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>APEX CONTROL — Sala de Espera</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <style>
  :root {
    --red:#E8190A; --cyan:#00E5FF; --bg:#0A0A0B; --bg2:#111115;
    --bg3:#18181E; --panel:#1C1C24; --border:#2A2A36;
    --text:#E8E8F0; --text-dim:#6B6B80; --text-muted:#3A3A50;
    --green:#00FF88; --yellow:#FFD600;
    --font-display:'Barlow Condensed',sans-serif;
    --font-mono:'Share Tech Mono',monospace;
  }
  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
  body {
    background:var(--bg); color:var(--text);
    font-family:var(--font-display);
    min-height:100vh; overflow:hidden;
  }

  /* ── FONDO ── */
  .bg-glow {
    position:fixed; inset:0; pointer-events:none; z-index:0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(232,25,10,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 80% 100%, rgba(0,229,255,0.05) 0%, transparent 60%);
  }

  .content { position:relative; z-index:1; display:flex; flex-direction:column; height:100vh; }

  /* ── HEADER ── */
  .wr-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 32px; border-bottom:1px solid var(--border);
    background:rgba(10,10,11,0.8); backdrop-filter:blur(8px);
    flex-shrink:0;
  }
  .wr-brand {
    font-size:1.4rem; font-weight:900; letter-spacing:0.08em; text-transform:uppercase;
    font-style:italic;
  }
  .wr-brand span { color:var(--red); }
  .wr-clock {
    font-family:var(--font-mono); font-size:1.1rem; color:var(--text-dim); letter-spacing:0.1em;
  }
  .live-pill {
    display:flex; align-items:center; gap:7px; background:rgba(0,255,136,0.1);
    border:1px solid rgba(0,255,136,0.3); padding:6px 14px; border-radius:3px;
    font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.15em; color:#00FF88;
  }
  .live-dot {
    width:7px; height:7px; border-radius:50%; background:#00FF88;
    animation:pulse 1s ease infinite;
  }
  @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* ── MAIN SPLIT ── */
  .wr-body { display:flex; flex:1; min-height:0; gap:0; }

  /* ── TURNO ACTUAL ── */
  .current-panel {
    flex:1; display:flex; flex-direction:column; align-items:center;
    justify-content:center; padding:40px;
    border-right:1px solid var(--border);
    position:relative; overflow:hidden;
  }
  .current-panel::before {
    content:''; position:absolute; inset:0;
    background:radial-gradient(ellipse 80% 60% at 50% 50%, rgba(0,255,136,0.04) 0%, transparent 70%);
  }
  .now-label {
    font-family:var(--font-mono); font-size:0.75rem; letter-spacing:0.3em;
    color:var(--green); text-transform:uppercase; margin-bottom:20px;
    display:flex; align-items:center; gap:8px;
  }
  .turn-number {
    font-size:clamp(5rem,15vw,11rem); font-weight:900; line-height:1;
    color:var(--cyan); letter-spacing:-0.02em; text-align:center;
    text-shadow:0 0 60px rgba(0,229,255,0.3);
    transition:all 0.4s ease;
  }
  .turn-name {
    font-size:clamp(1.5rem,4vw,3rem); font-weight:700; text-transform:uppercase;
    letter-spacing:0.05em; color:var(--text); margin-top:16px; text-align:center;
  }
  .turn-sub {
    font-family:var(--font-mono); font-size:0.85rem; color:var(--text-dim);
    letter-spacing:0.1em; margin-top:8px; text-align:center;
  }
  .no-turn {
    font-family:var(--font-mono); font-size:0.9rem; color:var(--text-muted);
    letter-spacing:0.2em; text-transform:uppercase; text-align:center;
  }

  /* ── COLA LATERAL ── */
  .queue-panel {
    width:360px; flex-shrink:0; display:flex; flex-direction:column;
    background:var(--bg2);
  }
  .queue-panel-title {
    font-size:0.9rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase;
    padding:18px 24px 14px; border-bottom:1px solid var(--border);
    color:var(--text-dim); font-family:var(--font-mono);
  }
  .queue-scroll { flex:1; overflow-y:auto; padding:12px; }
  .queue-scroll::-webkit-scrollbar { width:4px; }
  .queue-scroll::-webkit-scrollbar-track { background:transparent; }
  .queue-scroll::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }

  .q-item {
    display:flex; align-items:center; gap:14px;
    padding:14px 16px; border-radius:3px; margin-bottom:8px;
    background:var(--panel); border:1px solid var(--border);
    transition:all 0.3s ease; animation:slideIn 0.4s ease both;
  }
  @@keyframes slideIn { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
  .q-item.upnext {
    border-color:rgba(0,229,255,0.35); background:rgba(0,229,255,0.05);
  }
  .q-pos {
    font-size:1.6rem; font-weight:900; color:var(--text-muted);
    width:44px; text-align:center; flex-shrink:0;
  }
  .q-item.upnext .q-pos { color:var(--cyan); }
  .q-name { font-size:0.95rem; font-weight:700; text-transform:uppercase; }
  .q-id   { font-family:var(--font-mono); font-size:0.65rem; color:var(--text-dim); margin-top:2px; }

  /* ── BOTTOM ── */
  .wr-footer {
    padding:10px 32px; border-top:1px solid var(--border);
    background:rgba(10,10,11,0.8); backdrop-filter:blur(8px);
    display:flex; align-items:center; justify-content:space-between;
    font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.15em;
    color:var(--text-muted); text-transform:uppercase; flex-shrink:0;
  }

  /* ── ACTIVATE BUTTON (autoplay policy) ── */
  .activate-overlay {
    position:fixed; inset:0; background:rgba(10,10,11,0.92);
    z-index:9999; display:flex; align-items:center; justify-content:center;
    flex-direction:column; gap:20px;
  }
  .activate-overlay.hidden { display:none; }
  .activate-btn {
    padding:20px 48px; background:var(--cyan); border:none; border-radius:4px;
    color:var(--bg); font-family:var(--font-display); font-size:1.5rem;
    font-weight:900; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer;
    transition:opacity 0.2s;
  }
  .activate-btn:hover { opacity:0.85; }
  .activate-label {
    font-family:var(--font-mono); font-size:0.75rem; letter-spacing:0.2em;
    color:var(--text-dim); text-transform:uppercase;
  }
  </style>
</head>
<body>

  <div class="bg-glow"></div>

  <div class="activate-overlay" id="activateOverlay">
    <div class="activate-label">Pantalla de sala de espera</div>
    <button class="activate-btn" onclick="activateScreen()">Activar Pantalla</button>
    <div class="activate-label">Toca para habilitar audio y comenzar</div>
  </div>

  <div class="content">
    <header class="wr-header">
      <div class="wr-brand">KEPLER<span>TRACKLINE</span></div>
      <div class="live-pill">
        <div class="live-dot"></div>
        En Vivo
      </div>
      <div class="wr-clock" id="clock">--:--:--</div>
    </header>

    <main class="wr-body">
      <section class="current-panel">
        <div class="now-label">
          <div class="live-dot"></div>
          Turno en Atención
        </div>
        <div id="currentTurnDisplay" style="width:100%; display:flex; flex-direction:column; align-items:center;">
          <div class="no-turn">Sin turno activo</div>
        </div>
      </section>

      <aside class="queue-panel">
        <div class="queue-panel-title">
          <i class="bi bi-list-ol"></i> Próximos Turnos
        </div>
        <div class="queue-scroll" id="upcomingList">
          <div class="no-turn" style="padding:40px 0;">
            Cola vacía
          </div>
        </div>
      </aside>
    </main>

    <footer class="wr-footer">
      <div>KEPLER / TRACKLINE ALLIANCE</div>
      <div id="sessionLabel">Buscando sesión...</div>
      <div>Encrypted · Secure Display</div>
    </footer>
  </div>

  <script>
  let lastOnTrackId = null;
  let screenActive  = false;
  let pollInterval  = null;

  // ── Reloj ──────────────────────────────────────────────────────────────
  function updateClock() {
    const el = document.getElementById('clock');
    if (el) el.textContent = new Date().toLocaleTimeString('es-CO');
  }
  setInterval(updateClock, 1000);
  updateClock();

  // ── Activar pantalla (permite autoplay) ───────────────────────────────
  function activateScreen() {
    screenActive = true;
    document.getElementById('activateOverlay').classList.add('hidden');
    // Pre-cargar audio
    const a = new Audio('/sounds/estan-listos.mp3');
    a.volume = 0; a.play().catch(()=>{});
    startPolling();
  }

  // ── Polling ────────────────────────────────────────────────────────────
  function startPolling() {
    loadData();
    pollInterval = setInterval(loadData, 3000);
  }

  async function loadData() {
    try {
      // Buscar sesión activa
      const sr = await fetch('/Queue/GetActiveSession');
      const session = sr.ok ? await sr.json() : null;
      const sl = document.getElementById('sessionLabel');

      if (!session || !session.id) {
        if (sl) sl.textContent = 'Sin sesión activa';
        renderNoSession();
        return;
      }
      if (sl) sl.textContent = `Sesión: ${session.sessionCode}`;

      // Obtener cola
      const qr = await fetch(`/Queue/GetQueue?sessionId=${session.id}`);
      if (!qr.ok) return;
      const entries = await qr.json();

      renderCurrent(entries);
      renderUpcoming(entries);
    } catch (e) {
      console.error('Error actualizando sala de espera:', e);
    }
  }

  function renderNoSession() {
    document.getElementById('currentTurnDisplay').innerHTML =
      '<div class="no-turn">Sin sesión activa</div>';
    document.getElementById('upcomingList').innerHTML =
      '<div class="no-turn" style="padding:40px 0;">Cola vacía</div>';
  }

  function renderCurrent(entries) {
    const active = entries.find(e => e.status === 'ON_TRACK');
    const el     = document.getElementById('currentTurnDisplay');

    if (!active) {
      el.innerHTML = '<div class="no-turn">Sin turno activo</div>';
      lastOnTrackId = null;
      return;
    }

    // Si cambió el turno activo → reproducir sonido
    if (active.id !== lastOnTrackId && lastOnTrackId !== null) {
      playAlert();
      announceTTS(active.participant?.fullName, active.participant?.gridId);
    }
    lastOnTrackId = active.id;

    el.innerHTML = `
      <div class="turn-number">${String(active.position).padStart(2,'0')}</div>
      <div class="turn-name">${esc(active.participant?.fullName ?? '—')}</div>
      <div class="turn-sub">${esc(active.participant?.gridId ?? '—')} · Grade ${esc(active.participant?.grade ?? '?')}</div>`;
  }

  function renderUpcoming(entries) {
    const upcoming = entries.filter(e => e.status === 'UP_NEXT' || e.status === 'QUEUED');
    const el       = document.getElementById('upcomingList');

    if (!upcoming.length) {
      el.innerHTML = '<div class="no-turn" style="padding:40px 0;">No hay más turnos</div>';
      return;
    }

    el.innerHTML = upcoming.map((q, i) => `
      <div class="q-item ${q.status === 'UP_NEXT' ? 'upnext' : ''}">
        <div class="q-pos">${String(q.position).padStart(2,'0')}</div>
        <div class="q-info">
          <div class="q-name">${esc(q.participant?.fullName ?? '—')}</div>
          <div class="q-id">${esc(q.participant?.gridId ?? '—')} · Grade ${esc(q.participant?.grade ?? '?')}</div>
        </div>
        ${q.status === 'UP_NEXT' ? '<span class="live-dot" style="margin-left:auto;"></span>' : ''}
      </div>`).join('');
  }

  // ── Audio ──────────────────────────────────────────────────────────────
  function playAlert() {
    if (!screenActive) return;
    try {
      new Audio('/sounds/pase-a-la-pista.mp3').play().catch(()=>{});
    } catch(e) {}
  }

  function announceTTS(name, gridId) {
    if (!screenActive || !('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const msg = new SpeechSynthesisUtterance(
      `Turno para ${name || 'participante'}, código ${gridId || ''}, por favor pasar a la pista`
    );
    msg.lang = 'es-ES'; msg.rate = 0.85;
    window.speechSynthesis.speak(msg);
  }

  function esc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  </script>
</body>
</html>

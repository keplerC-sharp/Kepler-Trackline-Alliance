@model Kepler_Trackline_Alliance.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Driver Registry";
}

<div class="page-heading">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h1>Driver &amp; Vehicle Onboarding</h1>
      <p>Security Clearance Level 2 · Authorized Personnel Only</p>
    </div>
    <div style="text-align:right;">
      <div style="font-family:var(--font-display); font-size:1.1rem; font-weight:700;">
        MASTER DATABASE: <span style="color:var(--cyan);" id="totalEntries">0</span>
      </div>
      <div class="badge-session">SESSION UPLINK: <span id="sessionCode">—</span></div>
    </div>
  </div>
</div>

<!-- INFRASTRUCTURE: Print Server Configuration -->
<div class="print-config-bar">
  <i class="bi bi-printer" style="color:var(--cyan);"></i>
  <label>Print Server Gateway (IP:Port)</label>
  <input type="text" id="printServerIp" placeholder="192.168.1.105:3000">
  <button class="btn-outline" style="padding:6px 12px; font-size:0.7rem;" onclick="testPrintConnection()">
    <span class="print-status-dot" id="printStatusDot"></span>
    Ping Server
  </button>
  <span id="printStatusLabel" style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.1em; color:var(--text-muted); text-transform:uppercase;"></span>
</div>

<!-- NAVIGATION: Modular Onboarding Tabs -->
<div class="tab-nav mb-4">
  <button class="tab-btn active" onclick="switchTab('pilot', this)">Pilot Details</button>
  <button class="tab-btn" onclick="switchTab('vehicle', this)">Vehicle Specs</button>
  <button class="tab-btn" onclick="switchTab('search', this)">Assign to Queue</button>
</div>

<div class="row g-4">
  <!-- LEFT COLUMN: Data Entry Forms -->
  <div class="col-lg-6">

    <!-- COMPONENT: Pilot Registration Form -->
    <div id="tab-pilot" class="tab-panel active">
      <div class="z-panel red-accent">
        <div class="panel-title"><i class="bi bi-person-badge" style="color:var(--red);"></i> Participant Registration</div>
        <div class="panel-body">
          <div class="z-field">
            <label class="field-label">Legal Full Name</label>
            <input class="z-field-input" id="pilotName" type="text" placeholder="e.g. MARCUS VANDERGRIFT" oninput="validatePilotName(this)">
            <div class="field-error" id="pilotNameErr" style="display:none;"><i class="bi bi-exclamation-triangle"></i> Mandatory field</div>
          </div>

          <div class="z-field-row">
            <div class="z-field">
              <label class="field-label">Grid Identifier (ID)</label>
              <div class="driver-id-wrap">
                <input class="z-field-input" id="driverId" type="text" placeholder="KR-460-THX" oninput="checkDuplicateGridId(this)">
                <button class="verify-btn" onclick="verifyGridId()">
                  <i class="bi bi-shield-check"></i> Verify
                </button>
              </div>
              <div class="field-error" id="driverIdErr" style="display:none;"><i class="bi bi-exclamation-triangle"></i> ID Collision: Already Registered</div>
              <div class="field-success" id="driverIdOk" style="display:none;"><i class="bi bi-check-circle"></i> ID Valid: Available</div>
            </div>
            <div class="z-field">
              <label class="field-label">License Grade</label>
              <select class="z-field-input" id="licenseGrade">
                <option value="">Select Grade...</option>
                <option value="S">S — PLATINUM (Priority)</option>
                <option value="A">A — GOLD</option>
                <option value="B">B — SILVER</option>
              </select>
            </div>
          </div>

          <div class="z-field">
            <label class="field-label">Season Accumulation Points</label>
            <input class="z-field-input" id="seasonPoints" type="number" placeholder="0" min="0">
          </div>

          <div class="d-flex gap-2 flex-wrap">
            <button class="btn-primary" onclick="commitPilotRegistration()">
              <i class="bi bi-floppy"></i> Commit Registration
            </button>
            <button class="btn-outline" onclick="clearPilotForm()">
              <i class="bi bi-x-circle"></i> Purge Form
            </button>
          </div>

          <div id="pilotPrintArea" style="display:none; margin-top:14px;">
            <button class="btn-print" id="pilotPrintBtn" onclick="printPilotTicket()">
              <i class="bi bi-printer-fill"></i> Dispatch Pilot ID Ticket
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- COMPONENT: Vehicle Specification Form -->
    <div id="tab-vehicle" class="tab-panel">
      <div class="z-panel red-accent">
        <div class="panel-title"><i class="bi bi-car-front-fill" style="color:var(--red);"></i> Vehicle Onboarding Form</div>
        <div class="panel-body">
          <div class="z-field">
            <label class="field-label">Brand &amp; Chassis Model</label>
            <input class="z-field-input" id="carModel" type="text" placeholder="e.g. AUDI RS6, BMW M4">
          </div>
          <div class="z-field-row">
            <div class="z-field">
              <label class="field-label">Chassis Serial (VIN)</label>
              <input class="z-field-input" id="chassisNum" type="text" placeholder="VIN-######">
            </div>
            <div class="z-field">
              <label class="field-label">Assigned Pit Garage</label>
              <input class="z-field-input" id="pitGarage" type="text" placeholder="G-14">
            </div>
          </div>
          <div class="z-field">
            <label class="field-label">Competition Category</label>
            <select class="z-field-input" id="carCategory">
              <option value="">Select Category...</option>
              <option>GT3 Master</option><option>GT4 Challenger</option><option>Touring Class</option>
              <option>Formula Open</option><option>Super Sport</option><option>Open Track</option>
            </select>
          </div>
          <div class="z-field">
            <label class="field-label">Linked Grid Identifier</label>
            <input class="z-field-input" id="carDriverId" type="text" placeholder="KR-460-THX">
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <button class="btn-primary" onclick="commitVehicleRegistration()">
              <i class="bi bi-floppy"></i> Save Specs
            </button>
            <button class="btn-outline" onclick="clearVehicleForm()">
              <i class="bi bi-x-circle"></i> Reset Form
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- COMPONENT: Dynamic Search & Assignment -->
    <div id="tab-search" class="tab-panel">
      <div class="z-panel">
        <div class="panel-title"><i class="bi bi-search"></i> Database Query &amp; Queue Logic</div>
        <div class="panel-body">
          <div class="z-field" style="position:relative;">
            <label class="field-label">Search by Name or Grid ID</label>
            <input class="z-field-input" id="pilotSearch" type="text" placeholder="Query pilot data..." oninput="handlePilotSearch(this)" autocomplete="off">
            <div class="autocomplete-dropdown" id="autocompleteDropdown"></div>
          </div>
          <div id="selectedPilotCard" style="display:none;"></div>
          <div id="assignSection" style="display:none;">
            <div class="z-field">
              <label class="field-label">Stint Duration (Minutes)</label>
              <div class="duration-grid">
                <div class="duration-btn" onclick="selectDuration(this, 10)">10m</div>
                <div class="duration-btn" onclick="selectDuration(this, 15)">15m</div>
                <div class="duration-btn selected" onclick="selectDuration(this, 20)">20m</div>
                <div class="duration-btn" onclick="selectDuration(this, 30)">30m</div>
                <div class="duration-btn" onclick="selectDuration(this, 45)">45m</div>
                <div class="duration-btn" onclick="selectDuration(this, 60)">60m</div>
              </div>
            </div>
            <button class="btn-primary w-100" onclick="assignTurn()">
              <i class="bi bi-ticket-perforated"></i> Assign to Active Queue
            </button>
          </div>
          <div id="ticketDisplay" style="display:none; margin-top:16px;"></div>
        </div>
      </div>
    </div>

  </div>

  <!-- RIGHT COLUMN: Historical Registry View -->
  <div class="col-lg-6">
    <div class="z-panel">
      <div class="panel-title" style="justify-content:space-between; display:flex;">
        <span><i class="bi bi-clock-history"></i> Registry Record Log</span>
      </div>
      <div class="panel-body" id="recentEntriesList">
        <div style="color:var(--text-muted); font-family:var(--font-mono); font-size:0.7rem; text-align:center; padding:20px;">Synchronizing master list...</div>
      </div>
    </div>
    <div class="status-log mt-3">
      <div class="status-log-title">
        <span class="status-log-dot"></span>
        Uplink Status: Data Link Integrity 100%
      </div>
      <div class="status-log-body" id="systemStatusLog">
        Operational readiness confirmed. Waiting for user input.
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/registro.js" asp-append-version="true"></script>
}

@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KEPLER CONTROL — Ticket Audit Log</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow:wght@400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/styles.css">
</head>
<body>

<!-- GLOBAL NOTIFICATION LAYER -->
<div class="toast-container" id="toastContainer"></div>
<div class="overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

<div class="screen active" id="screen-dashboard" style="flex-direction:column;">
  <div class="topbar" id="topbar"><div class="topbar-brand"><span>CIRCUIT PRO: </span>PIT CONTROL</div></div>
  <div class="dashboard-body">
    <div class="sidebar" id="sidebar"></div>
    <div class="main-content">

      <!-- PAGE HEADER: Audit Controls & Filtering -->
      <div class="page-heading">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h1>Ticket Audit Log</h1>
            <p>Historical archive of generated track entries and registrations</p>
          </div>
          <div class="d-flex gap-2 align-items-center">
            <div style="display:flex; gap:6px;">
              <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
              <button class="filter-btn" onclick="setFilter('TURN', this)">Turns</button>
              <button class="filter-btn" onclick="setFilter('PILOT', this)">Pilots</button>
              <button class="filter-btn" onclick="setFilter('VEHICLE', this)">Vehicles</button>
            </div>
            <button class="btn-outline" style="padding:8px 14px; font-size:0.75rem;" onclick="clearAll()">
              <i class="bi bi-trash"></i> Purge Log
            </button>
          </div>
        </div>
      </div>

      <!-- INFRASTRUCTURE: Print Gateway Status -->
      <div class="print-config-bar">
        <i class="bi bi-printer" style="color:var(--cyan);"></i>
        <label>Print Dispatch Server</label>
        <input type="text" id="printServerIp" placeholder="192.168.1.105:3000">
        <button class="btn-outline" style="padding:6px 12px; font-size:0.7rem;" onclick="testPrintConnection()">
          <span class="print-status-dot" id="printStatusDot"></span>
          Verify Link
        </button>
        <span id="printStatusLabel" style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.1em; color:var(--text-muted); text-transform:uppercase;"></span>
      </div>

      <!-- DYNAMIC COMPONENT: Audit Grid -->
      <div id="tiquetesGrid" class="row g-3"></div>

      <!-- NULL STATE COMPONENT -->
      <div id="emptyState" style="display:none; text-align:center; padding:60px 20px;">
        <i class="bi bi-ticket-perforated" style="font-size:3rem; color:var(--text-muted);"></i>
        <div style="font-family:var(--font-mono); font-size:0.7rem; letter-spacing:0.2em; color:var(--text-muted); text-transform:uppercase; margin-top:16px;">
          No audit records found — <a href="/Dashboard/Index" style="color:var(--cyan);">Go to Registry</a>
        </div>
      </div>

    </div>
  </div>

  <!-- INFRASTRUCTURE STATUS -->
  <div class="bottom-bar">
    <div class="bottom-bar-item"><div class="dot blue"></div>Telemetry Link: Stable</div>
    <div class="bottom-bar-item"><div class="dot"></div>Local Node: Nominal</div>
    <div class="bottom-bar-item" style="margin-left:auto;">Secure Pit-to-Car Channel 04 Active</div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/shared.js" asp-append-version="true"></script>
<script src="~/js/tiquetes.js"></script>
</body>
</html>

@{ Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX CONTROL — Tiquetes</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow:wght@400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/styles.css">
</head>
<body>

<div class="toast-container" id="toastContainer"></div>
<div class="overlay" id="mobileOverlay" onclick="closeSidebar()"></div>

<div class="screen active" id="screen-dashboard" style="flex-direction:column;">
  <div class="topbar" id="topbar"></div>
  <div class="dashboard-body">
    <div class="sidebar" id="sidebar"></div>
    <div class="main-content">

      <div class="page-heading">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h1>Tiquetes</h1>
            <p>Historial de registros y turnos generados</p>
          </div>
          <div class="d-flex gap-2 align-items-center">
            <div style="display:flex; gap:6px;">
              <button class="filter-btn active" onclick="setFilter('all', this)">Todos</button>
              <button class="filter-btn" onclick="setFilter('TURNO', this)">Turnos</button>
              <button class="filter-btn" onclick="setFilter('PILOTO', this)">Pilotos</button>
              <button class="filter-btn" onclick="setFilter('VEHICULO', this)">Vehículos</button>
            </div>
            <button class="btn-outline" style="padding:8px 14px; font-size:0.75rem;" onclick="clearAll()">
              <i class="bi bi-trash"></i> Limpiar
            </button>
          </div>
        </div>
      </div>

      <!-- PRINT CONFIG -->
      <div class="print-config-bar">
        <i class="bi bi-printer" style="color:var(--cyan);"></i>
        <label>Servidor de impresión</label>
        <input type="text" id="printServerIp" placeholder="192.168.1.105:3000">
        <button class="btn-outline" style="padding:6px 12px; font-size:0.7rem;" onclick="testPrintConnection()">
          <span class="print-status-dot" id="printStatusDot"></span>
          Probar
        </button>
        <span id="printStatusLabel" style="font-family:var(--font-mono); font-size:0.6rem; letter-spacing:0.1em; color:var(--text-muted); text-transform:uppercase;"></span>
      </div>

      <div id="tiquetesGrid" class="row g-3"></div>

      <div id="emptyState" style="display:none; text-align:center; padding:60px 20px;">
        <i class="bi bi-ticket-perforated" style="font-size:3rem; color:var(--text-muted);"></i>
        <div style="font-family:var(--font-mono); font-size:0.7rem; letter-spacing:0.2em; color:var(--text-muted); text-transform:uppercase; margin-top:16px;">
          No hay tiquetes — <a href="/Dashboard/Index" style="color:var(--cyan);">ir a registrar</a>
        </div>
      </div>

    </div>
  </div>

  <div class="bottom-bar">
    <div class="bottom-bar-item"><div class="dot blue"></div>Sat-Link Stable</div>
    <div class="bottom-bar-item"><div class="dot"></div>Local Server Nominal</div>
    <div class="bottom-bar-item" style="margin-left:auto;">Encrypted Pit-to-Car Channel 04 Active</div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/shared.js"></script>
<script src="~/js/tiquetes.js"></script>
</body>
</html>

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "server=${{HOST}};port=3306;database=${{DB_NAME}};user=root;password=${{PASSWORD}}"
  },
  "SMTP": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "User": ${{GMAIL_USER}},
    "Pass": ${{G_PASSWORD}}
  },
  "AllowedHosts": "*"
}
